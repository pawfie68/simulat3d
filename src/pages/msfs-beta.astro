---
// MSFS Beta installation page — password protected (client-side)
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MSFS Interface — Beta Installation | Simulat3D</title>
<meta name="robots" content="noindex, nofollow">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --c-bg: #0a0c10;
    --c-bg2: #111318;
    --c-bg3: #181c22;
    --c-border: rgba(255,255,255,0.07);
    --c-border2: rgba(255,255,255,0.12);
    --c-accent: #00b4ff;
    --c-accent2: #0077cc;
    --c-text: #e8eaed;
    --c-muted: #7a8090;
    --c-dim: #3a404d;
    --c-success: #00e676;
    --font-head: 'Barlow Condensed', sans-serif;
    --font-body: 'Barlow', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--c-bg);
    color: var(--c-text);
    font-size: 16px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── GATE (password screen) ── */
  #gate {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 32px;
    padding: 40px 24px;
    position: relative;
  }
  .gate-grid {
    position: fixed; inset: 0; pointer-events: none;
    background-image:
      linear-gradient(var(--c-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--c-border) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black, transparent);
  }
  .gate-logo {
    font-family: var(--font-head);
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text);
    z-index: 1;
  }
  .gate-logo span { color: var(--c-accent); }
  .gate-box {
    background: var(--c-bg2);
    border: 1px solid var(--c-border2);
    border-radius: 6px;
    padding: 40px 48px;
    max-width: 420px;
    width: 100%;
    z-index: 1;
    text-align: center;
  }
  .gate-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--c-bg3); border: 1px solid var(--c-border2);
    color: var(--c-accent); font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 5px 12px; border-radius: 2px; margin-bottom: 20px;
  }
  .gate-badge::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--c-accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
  .gate-box h2 {
    font-family: var(--font-head);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .gate-box p {
    color: var(--c-muted);
    font-size: 14px;
    margin-bottom: 28px;
  }
  .gate-input {
    width: 100%;
    background: var(--c-bg3);
    border: 1px solid var(--c-dim);
    border-radius: 4px;
    color: var(--c-text);
    font-family: var(--font-body);
    font-size: 15px;
    padding: 12px 16px;
    outline: none;
    transition: border-color .2s;
    text-align: center;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }
  .gate-input:focus { border-color: var(--c-accent); }
  .gate-btn {
    width: 100%;
    font-family: var(--font-head); font-size: 15px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    background: var(--c-accent); color: #000;
    padding: 13px 32px; border-radius: 3px;
    border: none; cursor: pointer;
    transition: opacity .2s;
  }
  .gate-btn:hover { opacity: .85; }
  .gate-error {
    color: #ff5252;
    font-size: 13px;
    margin-top: 12px;
    display: none;
  }

  /* ── MAIN CONTENT ── */
  #content { display: none; }

  header {
    position: sticky; top: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: rgba(10,12,16,0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--c-border);
  }
  .header-logo {
    font-family: var(--font-head);
    font-size: 20px; font-weight: 700; letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-text); text-decoration: none;
  }
  .header-logo span { color: var(--c-accent); }
  .header-badge {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--c-accent);
    background: var(--c-bg3); border: 1px solid var(--c-border2);
    padding: 4px 10px; border-radius: 2px;
  }

  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 40px 120px;
  }

  .page-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--c-bg3); border: 1px solid var(--c-border2);
    color: var(--c-accent); font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 5px 12px; border-radius: 2px; margin-bottom: 24px;
  }
  .page-badge::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--c-accent);
    animation: pulse 2s ease-in-out infinite;
  }
  h1 {
    font-family: var(--font-head);
    font-size: clamp(36px, 6vw, 60px);
    font-weight: 700; line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  h1 em { font-style: normal; color: var(--c-accent); }
  .subtitle {
    font-size: 17px; font-weight: 300; color: var(--c-muted);
    max-width: 580px; line-height: 1.7;
    margin-bottom: 56px;
  }

  /* ── DOWNLOAD BUTTON ── */
  .download-section {
    background: var(--c-bg2);
    border: 1px solid var(--c-border2);
    border-left: 3px solid var(--c-accent);
    border-radius: 6px;
    padding: 28px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 64px;
    flex-wrap: wrap;
  }
  .download-info { flex: 1; }
  .download-info strong {
    font-family: var(--font-head);
    font-size: 18px; font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
    display: block; margin-bottom: 4px;
  }
  .download-info span { color: var(--c-muted); font-size: 14px; }
  .btn-download {
    font-family: var(--font-head); font-size: 15px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    background: var(--c-accent); color: #000;
    padding: 13px 28px; border-radius: 3px; text-decoration: none;
    white-space: nowrap;
    transition: opacity .2s, transform .2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-download:hover { opacity: .85; transform: translateY(-1px); }
  .btn-download svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* ── STEPS ── */
  .steps-title {
    font-family: var(--font-head);
    font-size: 13px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--c-muted);
    margin-bottom: 24px;
  }
  .steps { display: flex; flex-direction: column; gap: 16px; }
  .step {
    display: flex;
    gap: 20px;
    background: var(--c-bg2);
    border: 1px solid var(--c-border);
    border-radius: 6px;
    padding: 22px 24px;
    transition: border-color .2s;
  }
  .step:hover { border-color: var(--c-border2); }
  .step-num {
    font-family: var(--font-head);
    font-size: 28px; font-weight: 700;
    color: var(--c-accent);
    line-height: 1;
    min-width: 32px;
    flex-shrink: 0;
  }
  .step-body { flex: 1; }
  .step-body h3 {
    font-family: var(--font-head);
    font-size: 17px; font-weight: 600;
    letter-spacing: 0.03em; text-transform: uppercase;
    margin-bottom: 6px;
  }
  .step-body p {
    color: var(--c-muted);
    font-size: 14px;
    line-height: 1.65;
  }
  .step-body code {
    font-family: 'Courier New', monospace;
    font-size: 13px;
    background: var(--c-bg3);
    border: 1px solid var(--c-dim);
    color: var(--c-accent);
    padding: 2px 7px;
    border-radius: 3px;
    word-break: break-all;
  }

  .note {
    margin-top: 48px;
    background: var(--c-bg2);
    border: 1px solid var(--c-dim);
    border-radius: 6px;
    padding: 20px 24px;
    font-size: 14px;
    color: var(--c-muted);
    line-height: 1.7;
  }
  .note strong { color: var(--c-text); }

  @media (max-width: 640px) {
    header { padding: 0 20px; }
    main { padding: 48px 20px 80px; }
    .download-section { padding: 20px; }
    .step { padding: 18px 16px; }
  }
</style>
</head>
<body>

<!-- PASSWORD GATE -->
<div id="gate">
  <div class="gate-grid"></div>
  <div class="gate-logo">Simulat<span>3D</span></div>
  <div class="gate-box">
    <div class="gate-badge">Beta Access</div>
    <h2>Enter Password</h2>
    <p>This page is restricted to beta testers only.</p>
    <input class="gate-input" type="password" id="pwd" placeholder="Password" autocomplete="off">
    <button class="gate-btn" id="access-btn" type="button">Access</button>
    <div class="gate-error" id="gate-error">Incorrect password. Please try again.</div>
  </div>
</div>

<!-- MAIN CONTENT -->
<div id="content">
  <header>
    <a href="/" class="header-logo">Simulat<span>3D</span></a>
    <span class="header-badge">Beta</span>
  </header>

  <main>
    <div class="page-badge">MSFS Interface</div>
    <h1>Installation <em>Guide</em></h1>
    <p class="subtitle">
      Follow the steps below to install the new MSFS Interface plugin for SkalarkiIO Profiler.
      Please read each step carefully before proceeding.
    </p>

    <!-- DOWNLOAD -->
    <div class="download-section">
      <div class="download-info">
        <strong>MSFS Interface — Beta Package</strong>
        <span>SkalarkiIO Profiler 5.1 compatible</span>
      </div>
      <a href="/downloads/SKALARKIe_MSFSInterface_v2.23.zip" class="btn-download" download>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download
      </a>
    </div>

    <!-- STEPS -->
    <p class="steps-title">Installation steps</p>
    <div class="steps">

      <div class="step">
        <div class="step-num">01</div>
        <div class="step-body">
          <h3>Download the package</h3>
          <p>Use the download button above to get the beta package file. Save it somewhere you can easily find it.</p>
        </div>
      </div>

      <div class="step">
        <div class="step-num">02</div>
        <div class="step-body">
          <h3>Close all applications</h3>
          <p>Close <strong>Microsoft Flight Simulator</strong> and <strong>SkalarkiIO Profiler</strong> before continuing. Make sure both are fully shut down.</p>
        </div>
      </div>

      <div class="step">
        <div class="step-num">03</div>
        <div class="step-body">
          <h3>Clear the plugin folder</h3>
          <p>Navigate to the SkalarkiIO Profiler MSFS folder (default location) and <strong>delete all files</strong> inside it:</p>
          <br>
          <p style="font-size:13px; color: var(--c-muted); margin-bottom: 8px;">Note: The folder name <code>MSFS2020</code> is unrelated to your MSFS version — the plugin works with both <strong style="color:var(--c-text)">MSFS 2020 and MSFS 2024</strong> regardless of the folder name.</p>
          <code>C:\Program Files (x86)\SkalarkiIO Profiler 5.1\MSFS2020</code>
        </div>
      </div>

      <div class="step">
        <div class="step-num">04</div>
        <div class="step-body">
          <h3>Extract and copy the new files</h3>
          <p>Extract the downloaded archive, then move <strong>all its contents</strong> into the now-empty folder:</p>
          <br>
          <code>C:\Program Files (x86)\SkalarkiIO Profiler 5.1\MSFS2020</code>
        </div>
      </div>

      <div class="step">
        <div class="step-num">05</div>
        <div class="step-body">
          <h3>Launch SkalarkiIO Profiler</h3>
          <p>Start SkalarkiIO Profiler. The new MSFS Interface should launch automatically. On first run, you may be prompted to install additional runtime components — accept and proceed.</p>
        </div>
      </div>

      <div class="step">
        <div class="step-num">06</div>
        <div class="step-body">
          <h3>Automatic MSFS detection</h3>
          <p>MSFS Interface will automatically detect your version of Microsoft Flight Simulator and install the appropriate files. No manual configuration is required.</p>
        </div>
      </div>

      <div class="step">
        <div class="step-num">07</div>
        <div class="step-body">
          <h3>Start flying</h3>
          <p>You can now launch Microsoft Flight Simulator. All supported Skalarki devices should be detected and fully operational.</p>
        </div>
      </div>

    </div>

    <div class="note">
      <strong>Note:</strong> This is a beta release. If you encounter any issues during installation or use, please contact us at
      <a href="mailto:info@simulat3d.eu" style="color: var(--c-accent);">info@simulat3d.eu</a>.
      Include your SkalarkiIO Profiler version and a description of the problem.
    </div>
  </main>
</div>

<script>
  document.getElementById('access-btn').addEventListener('click', checkPassword);
  document.getElementById('pwd').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') checkPassword();
  });

  function checkPassword() {
    const input = document.getElementById('pwd').value;
    if (input === 'BetaTest2026') {
      document.getElementById('gate').style.display = 'none';
      document.getElementById('content').style.display = 'block';
    } else {
      const err = document.getElementById('gate-error');
      err.style.display = 'block';
      document.getElementById('pwd').value = '';
      document.getElementById('pwd').focus();
    }
  }
</script>

</body>
</html>
