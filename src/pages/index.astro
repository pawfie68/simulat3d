function setLang(lang) {
  localStorage.setItem('lang', lang);
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.dataset.i18n;
    if (t[lang][key] !== undefined) el.innerHTML = t[lang][key];
  });
  document.querySelectorAll('[data-i18n-ph]').forEach(el => {
    const key = el.dataset.i18nPh;
    if (t[lang][key] !== undefined) el.placeholder = t[lang][key];
  });
  // cookie bar translations (not data-i18n tagged to avoid innerHTML on button)
  const ct = document.getElementById('cookie-text');
  const ca = document.getElementById('cookie-accept');
  const cr = document.getElementById('cookie-reject');
  if (ct) ct.textContent = t[lang]['cookie-text'];
  if (ca) ca.textContent = t[lang]['cookie-accept'];
  if (cr) cr.textContent = t[lang]['cookie-reject'];

  document.getElementById('btn-pl').classList.toggle('active', lang === 'pl');
  document.getElementById('btn-en').classList.toggle('active', lang === 'en');
  document.documentElement.lang = lang;
}

const saved = localStorage.getItem('lang') || 'pl';
setLang(saved);

// Cookie banner
(function() {
  const bar = document.getElementById('cookie-bar');
  if (!bar) return;
  if (!localStorage.getItem('cookie-consent')) {
    setTimeout(() => bar.classList.add('visible'), 600);
  }
  document.getElementById('cookie-accept').addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'accepted');
    bar.classList.remove('visible');
  });
  document.getElementById('cookie-reject').addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'rejected');
    bar.classList.remove('visible');
  });
})();
