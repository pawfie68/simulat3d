<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>

  :root {
    --c-bg: #0a0c10;
    --c-bg2: #111318;
    --c-bg3: #181c22;
    --c-border: rgba(255,255,255,0.07);
    --c-border2: rgba(255,255,255,0.12);
    --c-accent: #00b4ff;
    --c-accent2: #0077cc;
    --c-accent-glow: rgba(0,180,255,0.15);
    --c-text: #e8eaed;
    --c-muted: #7a8090;
    --c-dim: #3a404d;
    --font-head: 'Barlow Condensed', sans-serif;
    --font-body: 'Barlow', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--c-bg);
    color: var(--c-text);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NAV ─────────────────────────────────────────── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: rgba(10,12,16,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--c-border);
  }
  .nav-logo {
    font-family: var(--font-head);
    font-size: 22px; font-weight: 700; letter-spacing: 0.04em;
    color: var(--c-text); text-decoration: none;
  }
  .nav-logo span { color: var(--c-accent); }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    font-size: 13px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--c-muted); text-decoration: none;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--c-text); }
  .nav-cta {
    font-size: 13px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--c-accent); text-decoration: none;
    border: 1px solid var(--c-accent2);
    padding: 7px 18px; border-radius: 4px;
    transition: background .2s, color .2s;
  }
  .nav-cta:hover { background: var(--c-accent); color: #000; }

  /* ── HERO ────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    padding: 120px 48px 80px;
    position: relative; overflow: hidden;
  }
  .hero-grid {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
      linear-gradient(var(--c-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--c-border) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black, transparent);
  }
  .hero-glow {
    position: absolute; top: 20%; left: 50%; transform: translateX(-50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, rgba(0,180,255,0.08), transparent 70%);
    pointer-events: none;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--c-bg3); border: 1px solid var(--c-border2);
    color: var(--c-accent); font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 5px 12px; border-radius: 2px; margin-bottom: 28px;
  }
  .hero-badge::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--c-accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }

  .hero h1 {
    font-family: var(--font-head);
    font-size: clamp(52px, 8vw, 100px);
    font-weight: 700; line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    max-width: 900px;
  }
  .hero h1 em { font-style: normal; color: var(--c-accent); }
  .hero-sub {
    margin-top: 28px;
    font-size: 17px; font-weight: 300; color: var(--c-muted);
    max-width: 520px; line-height: 1.7;
  }
  .hero-actions {
    display: flex; gap: 16px; margin-top: 48px; flex-wrap: wrap;
  }
  .btn-primary {
    font-family: var(--font-head); font-size: 15px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    background: var(--c-accent); color: #000;
    padding: 14px 32px; border-radius: 3px; text-decoration: none;
    transition: opacity .2s, transform .2s;
  }
  .btn-primary:hover { opacity: .85; transform: translateY(-1px); }
  .btn-secondary {
    font-family: var(--font-head); font-size: 15px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--c-text);
    border: 1px solid var(--c-dim);
    padding: 14px 32px; border-radius: 3px; text-decoration: none;
    transition: border-color .2s, color .2s;
  }
  .btn-secondary:hover { border-color: var(--c-text); }

  .hero-scroll {
    margin-top: 80px;
    display: flex; align-items: center; gap: 12px;
    color: var(--c-muted); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
  }
  .hero-scroll::before {
    content: ''; display: block; width: 40px; height: 1px; background: var(--c-dim);
  }

  /* ── SECTION SHARED ──────────────────────────────── */
  section { padding: 100px 48px; }
  .section-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--c-accent); margin-bottom: 16px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before { content: '//'; opacity: .5; }
  .section-title {
    font-family: var(--font-head);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 700; text-transform: uppercase;
    line-height: 1; letter-spacing: 0.01em;
  }
  .section-title em { font-style: normal; color: var(--c-accent); }

  /* ── SIMULATORS ──────────────────────────────────── */
  #simulators { background: var(--c-bg2); }
  .sim-intro { max-width: 600px; margin-bottom: 60px; }
  .sim-intro p { color: var(--c-muted); margin-top: 20px; font-size: 16px; line-height: 1.8; }

  .sim-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2px;
    background: var(--c-border);
    border: 1px solid var(--c-border);
  }
  .sim-card {
    background: var(--c-bg2);
    padding: 40px;
    position: relative; overflow: hidden;
    transition: background .25s;
  }
  .sim-card:hover { background: var(--c-bg3); }
  .sim-card::after {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 2px; background: var(--c-accent);
    transform: scaleX(0); transform-origin: left;
    transition: transform .3s;
  }
  .sim-card:hover::after { transform: scaleX(1); }
  .sim-card-type {
    font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--c-accent); margin-bottom: 20px;
  }
  .sim-card h3 {
    font-family: var(--font-head); font-size: 28px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.02em; line-height: 1;
    margin-bottom: 12px;
  }
  .sim-card p { color: var(--c-muted); font-size: 14px; line-height: 1.7; margin-bottom: 28px; }
  .sim-tag {
    display: inline-block;
    background: var(--c-bg);
    border: 1px solid var(--c-border2);
    color: var(--c-muted); font-size: 11px; letter-spacing: 0.08em;
    padding: 3px 10px; border-radius: 2px; margin: 2px 2px 2px 0;
  }
  .sim-status {
    margin-top: 24px;
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; color: var(--c-muted);
  }
  .sim-status .dot {
    width: 6px; height: 6px; border-radius: 50%;
  }
  .dot-green { background: #22c55e; box-shadow: 0 0 6px rgba(34,197,94,.4); }
  .dot-amber { background: #f59e0b; box-shadow: 0 0 6px rgba(245,158,11,.4); }

  /* ── SERVICES ────────────────────────────────────── */
  #uslugi { border-top: 1px solid var(--c-border); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 28px; margin-top: 56px;
  }
  .service-item {
    padding: 32px;
    border: 1px solid var(--c-border);
    border-radius: 2px;
    transition: border-color .2s, background .2s;
  }
  .service-item:hover {
    border-color: var(--c-border2);
    background: var(--c-bg2);
  }
  .service-icon {
    width: 40px; height: 40px; margin-bottom: 20px;
    color: var(--c-accent);
  }
  .service-item h4 {
    font-family: var(--font-head); font-size: 18px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px;
  }
  .service-item p { color: var(--c-muted); font-size: 14px; line-height: 1.7; }

  /* ── TECH STRIP ──────────────────────────────────── */
  .tech-strip {
    background: var(--c-bg3);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    padding: 28px 48px;
    display: flex; align-items: center; gap: 40px; overflow: hidden;
  }
  .tech-strip-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--c-muted); white-space: nowrap; flex-shrink: 0;
  }
  .tech-items {
    display: flex; gap: 40px; flex-wrap: wrap;
  }
  .tech-item {
    font-family: var(--font-head); font-size: 15px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--c-dim);
    transition: color .2s;
  }
  .tech-item:hover { color: var(--c-muted); }

  /* ── ABOUT ───────────────────────────────────────── */
  #o-firmie {
    background: var(--c-bg2);
    border-top: 1px solid var(--c-border);
  }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; margin-top: 60px; align-items: start;
  }
  .about-text p {
    color: var(--c-muted); font-size: 16px; line-height: 1.8;
    margin-bottom: 20px;
  }
  .about-text p strong { color: var(--c-text); font-weight: 500; }
  .about-stats {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
    background: var(--c-border);
    border: 1px solid var(--c-border);
  }
  .stat-item {
    background: var(--c-bg2);
    padding: 32px 28px;
  }
  .stat-number {
    font-family: var(--font-head); font-size: 48px; font-weight: 700;
    color: var(--c-accent); line-height: 1;
  }
  .stat-label {
    font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--c-muted); margin-top: 8px;
  }

  /* ── SHOP TEASER ─────────────────────────────────── */
  #sklep {
    border-top: 1px solid var(--c-border);
    text-align: center;
  }
  .shop-teaser {
    max-width: 560px; margin: 0 auto; padding-top: 24px;
  }
  .shop-teaser p { color: var(--c-muted); margin-top: 20px; margin-bottom: 40px; line-height: 1.7; }
  .shop-placeholder {
    border: 1px dashed var(--c-dim);
    padding: 60px 40px;
    border-radius: 4px;
    margin-top: 48px;
  }
  .shop-placeholder p {
    color: var(--c-dim); font-size: 14px; margin: 0;
  }

  /* ── CONTACT ─────────────────────────────────────── */
  #kontakt {
    background: var(--c-bg2);
    border-top: 1px solid var(--c-border);
  }
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; margin-top: 60px;
  }
  .contact-info h3 {
    font-family: var(--font-head); font-size: 22px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.04em;
    margin-bottom: 24px;
  }
  .contact-line {
    display: flex; flex-direction: column;
    margin-bottom: 20px;
  }
  .contact-line span:first-child {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--c-muted); margin-bottom: 4px;
  }
  .contact-line a, .contact-line span:last-child {
    font-size: 16px; color: var(--c-text); text-decoration: none;
    transition: color .2s;
  }
  .contact-line a:hover { color: var(--c-accent); }
  .contact-form { display: flex; flex-direction: column; gap: 16px; }
  .contact-form input,
  .contact-form textarea {
    background: var(--c-bg);
    border: 1px solid var(--c-border2);
    color: var(--c-text);
    font-family: var(--font-body); font-size: 15px;
    padding: 13px 16px; border-radius: 3px;
    outline: none; transition: border-color .2s;
    width: 100%;
  }
  .contact-form input:focus,
  .contact-form textarea:focus { border-color: var(--c-accent); }
  .contact-form textarea { resize: vertical; min-height: 120px; }
  .contact-form ::placeholder { color: var(--c-dim); }

  /* ── FOOTER ──────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--c-border);
    padding: 32px 48px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
  }
  .footer-logo {
    font-family: var(--font-head); font-size: 18px; font-weight: 700;
    color: var(--c-muted); text-decoration: none; letter-spacing: 0.04em;
  }
  .footer-logo span { color: var(--c-accent); }
  .footer-links { display: flex; gap: 24px; list-style: none; }
  .footer-links a {
    font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--c-dim); text-decoration: none; transition: color .2s;
  }
  .footer-links a:hover { color: var(--c-muted); }
  .footer-copy { font-size: 12px; color: var(--c-dim); }

  /* ── LANG SWITCH ─────────────────────────────────── */
  .lang-switch {
    display: flex; align-items: center; gap: 2px;
    border: 1px solid var(--c-border2);
    border-radius: 3px; overflow: hidden; margin-left: 12px;
    flex-shrink: 0;
  }
  .lang-btn {
    font-family: var(--font-head); font-size: 12px; font-weight: 600;
    letter-spacing: 0.08em;
    background: none; border: none; cursor: pointer;
    padding: 5px 10px; color: var(--c-muted);
    transition: background .15s, color .15s;
  }
  .lang-btn.active {
    background: var(--c-accent); color: #000;
  }
  .lang-btn:not(.active):hover { color: var(--c-text); }

  /* ── WIP BANNER ──────────────────────────────────── */
  .wip-banner {
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 200;
    background: var(--c-bg3);
    border: 1px solid rgba(245,158,11,0.4);
    box-shadow: 0 0 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(245,158,11,0.1);
    padding: 40px 56px;
    text-align: center;
    border-radius: 4px;
    max-width: 480px; width: calc(100% - 48px);
    pointer-events: none;
  }
  .wip-banner-label {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: #f59e0b;
    margin-bottom: 14px;
  }
  .wip-banner-label::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: #f59e0b;
    animation: pulse 2s ease-in-out infinite;
  }
  .wip-banner p {
    font-size: 15px; color: var(--c-muted); line-height: 1.7;
  }

  /* ── COOKIE BANNER ───────────────────────────────── */
  .cookie-bar {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 300;
    background: var(--c-bg3);
    border-top: 1px solid var(--c-border2);
    box-shadow: 0 -8px 40px rgba(0,0,0,0.5);
    padding: 20px 48px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; flex-wrap: wrap;
    transform: translateY(100%);
    transition: transform .4s cubic-bezier(.16,1,.3,1);
  }
  .cookie-bar.visible { transform: translateY(0); }
  .cookie-bar p {
    font-size: 13px; color: var(--c-muted); line-height: 1.6;
    max-width: 640px; flex: 1;
  }
  .cookie-bar p a {
    color: var(--c-accent); text-decoration: none;
  }
  .cookie-bar p a:hover { text-decoration: underline; }
  .cookie-actions {
    display: flex; gap: 10px; flex-shrink: 0;
  }
  .cookie-accept {
    font-family: var(--font-head); font-size: 13px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    background: var(--c-accent); color: #000;
    border: none; padding: 9px 22px; border-radius: 3px; cursor: pointer;
    transition: opacity .2s;
  }
  .cookie-accept:hover { opacity: .85; }
  .cookie-reject {
    font-family: var(--font-head); font-size: 13px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    background: none; color: var(--c-muted);
    border: 1px solid var(--c-dim); padding: 9px 22px; border-radius: 3px; cursor: pointer;
    transition: border-color .2s, color .2s;
  }
  .cookie-reject:hover { border-color: var(--c-muted); color: var(--c-text); }

  @media (max-width: 768px) {
    nav { padding: 0 20px; }
