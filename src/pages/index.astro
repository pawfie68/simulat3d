---
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';

function parseFrontmatter(content: string) {
  const match = content.match(/^---\r?\n([\s\S]*?)\r?\n---/);
  if (!match) return {};
  const data: Record<string, any> = {};
  const lines = match[1].split('\n');
  let currentKey = '';
  let currentVal = '';
  for (const line of lines) {
    const colonIdx = line.indexOf(':');
    if (colonIdx === -1) continue;
    const key = line.slice(0, colonIdx).trim();
    const val = line.slice(colonIdx + 1).trim().replace(/^["']|["']$/g, '');
    if (key) {
      data[key] = val;
      currentKey = key;
    }
  }
  return data;
}

const simDir = join(process.cwd(), 'src/content/symulatory');
const symulatory = readdirSync(simDir)
  .filter(f => f.endsWith('.md'))
  .map(f => parseFrontmatter(readFileSync(join(simDir, f), 'utf8')))
  .sort((a, b) => Number(a.order) - Number(b.order));

const uslugiDir = join(process.cwd(), 'src/content/uslugi');
const uslugi = readdirSync(uslugiDir)
  .filter(f => f.endsWith('.md'))
  .map(f => parseFrontmatter(readFileSync(join(uslugiDir, f), 'utf8')))
  .sort((a, b) => Number(a.order) - Number(b.order));

const kontakt = JSON.parse(readFileSync(join(process.cwd(), 'src/data/kontakt.json'), 'utf8'));

const statusDot = (status: string) =>
  status === 'W przygotowaniu' ? 'dot-amber' : 'dot-green';
